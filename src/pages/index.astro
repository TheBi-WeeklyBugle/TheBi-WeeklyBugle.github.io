---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return data.draft !== true;
})).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <p class="label">Editor's note</p>
        <h1>Welcome to the best blog on the internet.</h1>
        <p class="bio">A home for everything and anything.</p>
        <a href="/blog">Read all posts →</a>
      </section>

      <section class="latest">
        <p class="label">Latest essays</p>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <div>
                  <p class="post-title">{post.data.title}</p>
                  <p class="post-desc">{post.data.description}</p>
                </div>
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .label {
    font-size: 1em;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--gray));
    margin: 0 0 0.5rem;
  }
  .bio {
    color: rgb(var(--gray-dark));
  }
  .intro a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 0.5px solid var(--accent);
    padding-bottom: 1px;
  }
  .latest {
    margin-top: 2.5rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  ul a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    border: 0.5px solid rgb(var(--gray-light));
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  ul a:hover {
    border-color: rgb(var(--gray));
    box-shadow: var(--box-shadow);
  }
  .post-title {
    font-weight: 700;
    margin: 0 0 0.3rem;
  }
  .post-desc {
    color: rgb(var(--gray));
    margin: 0;
  }
  .post-date {
    color: rgb(var(--gray));
    white-space: nowrap;
    margin-left: 1rem;
    margin-top: 2px;
  }
</style>