---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
  return data.draft !== true;
})).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <p class="label">Editor's note</p>
        <h1>Welcome to The Bi-Weekly Bugle</h1>
        <p class="bio">A home for essays on whatever's been on my mind lately — culture, ideas, and the occasional rant. New pieces drop every two weeks.</p>
        <a href="/blog">Read all posts →</a>
      </section>

      <section class="latest">
        <p class="label">Latest essays</p>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <div>
                  <p class="post-title">{post.data.title}</p>
                  <p class="post-desc">{post.data.description}</p>
                </div>
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 700px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
  .label {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #888;
    margin: 0 0 0.5rem;
  }
  h1 {
    font-size: 28px;
    font-weight: 500;
    margin: 0 0 0.75rem;
    line-height: 1.3;
  }
  .bio {
    font-size: 15px;
    color: #555;
    line-height: 1.7;
    margin: 0 0 1rem;
  }
  .intro a {
    font-size: 14px;
    color: #378ADD;
    text-decoration: none;
    border-bottom: 0.5px solid #378ADD;
    padding-bottom: 1px;
  }
  .latest {
    margin-top: 2.5rem;
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  ul a {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    text-decoration: none;
    color: inherit;
    border: 0.5px solid #e0e0e0;
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  ul a:hover {
    border-color: #aaa;
  }
  .post-title {
    font-size: 15px;
    font-weight: 500;
    margin: 0 0 0.3rem;
  }
  .post-desc {
    font-size: 13px;
    color: #888;
    margin: 0;
    line-height: 1.5;
  }
  .post-date {
    font-size: 12px;
    color: #aaa;
    white-space: nowrap;
    margin-left: 1rem;
    margin-top: 2px;
  }
</style>